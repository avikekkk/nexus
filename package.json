{
  "name": "db-tui",
  "module": "src/index.tsx",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "bun run src/index.tsx",
    "dev": "bun --watch run src/index.tsx",
    "build:bin": "bun run build:bin:linux-x64 && bun run build:bin:linux-arm64 && bun run build:bin:macos-x64 && bun run build:bin:macos-arm64 && bun run build:bin:windows-x64 && bun run build:bin:windows-arm64",
    "build:bin:linux-x64": "bun build src/index.tsx --compile --target=bun-linux-x64 --outfile build/db-linux-x64",
    "build:bin:linux-arm64": "bun build src/index.tsx --compile --target=bun-linux-arm64 --outfile build/db-linux-arm64",
    "build:bin:macos-x64": "bun build src/index.tsx --compile --target=bun-darwin-x64 --outfile build/db-macos-x64",
    "build:bin:macos-arm64": "bun build src/index.tsx --compile --target=bun-darwin-arm64 --outfile build/db-macos-arm64",
    "build:bin:windows-x64": "bun build src/index.tsx --compile --target=bun-windows-x64 --outfile build/db-windows-x64.exe",
    "build:bin:windows-arm64": "bun build src/index.tsx --compile --target=bun-windows-arm64 --outfile build/db-windows-arm64.exe"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/ioredis": "^5.0.0",
    "@types/pg": "^8.15.6",
    "@types/react": "^19.2.14"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@napi-rs/keyring": "^1.2.0",
    "@opentui/core": "^0.1.87",
    "@opentui/react": "^0.1.87",
    "ioredis": "^5.10.0",
    "mongodb": "^7.1.0",
    "mysql2": "^3.19.1",
    "pg": "^8.16.3",
    "react": "^19.2.4"
  }
}
